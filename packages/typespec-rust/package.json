{
  "name": "@azure-tools/typespec-rust",
  "version": "0.41.1",
  "description": "TypeSpec emitter for Rust SDKs",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "tspMain": "dist/src/index.js",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "spector": "node .scripts/spector.js",
    "clean": "ver > nul 2>&1 nul && npm run --silent clean-cmd || npm run --silent clean-bash",
    "clean-cmd": "if exist dist rmdir /s /q dist && exit 0 || exit 0 ",
    "clean-bash": "rm nul && rm -rf dist && exit 0 || exit 0",
    "build": "tsc -p .",
    "test": "vitest run",
    "test-ci": "vitest run --coverage --reporter=junit --reporter=default --no-file-parallelism",
    "tspcompile": "node .scripts/tspcompile.js",
    "watch": "tsc -p . --watch",
    "workspace-members": "node .scripts/workspace-members.js"
  },
  "files": [
    "dist/src/**",
    "!dist/test/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azure/typespec-rust.git"
  },
  "keywords": [
    "typespec",
    "rust",
    "rustlang",
    "typespec"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Azure/typespec-rust/issues"
  },
  "homepage": "https://github.com/Azure/typespec-rust#readme",
  "readme": "https://github.com/Azure/typespec-rust/blob/main/readme.md",
  "devDependencies": {
    "@azure-tools/azure-http-specs": "0.1.0-alpha.40",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@types/turndown": "^5.0.6",
    "@typespec/http-specs": "0.1.0-alpha.37",
    "@typespec/spector": "0.1.0-alpha.25",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@azure-tools/typespec-azure-resource-manager": "0.68.0",
    "@typespec/openapi": "1.12.0",
    "@typespec/rest": "0.82.0",
    "@typespec/versioning": "0.82.0",
    "@typespec/xml": "0.82.0",
    "fast-xml-parser": ">=5.7.0",
    "flatted": ">=3.4.2",
    "minimatch": ">=10.2.3",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "rollup": ">=4.59.0",
    "uuid": ">=14.0.0",
    "vite": ">=7.3.2",
    "yaml": ">=2.8.3"
  },
  "dependencies": {
    "@azure-tools/typespec-azure-core": "0.68.0",
    "@azure-tools/typespec-client-generator-core": "0.68.3",
    "@typespec/compiler": "1.12.0",
    "@typespec/http": "1.12.0",
    "linkifyjs": "^4.3.2",
    "query-string": "9.3.1",
    "source-map-support": "0.5.21",
    "turndown": "^7.2.4"
  },
  "azure-sdk/emitter-package-json-pinning": [
    "@azure-tools/typespec-azure-core",
    "@azure-tools/typespec-azure-resource-manager",
    "@azure-tools/typespec-client-generator-core",
    "@typespec/compiler",
    "@typespec/http",
    "@typespec/openapi",
    "@typespec/rest",
    "@typespec/versioning",
    "@typespec/xml"
  ]
}